# Копируется в .env (он в .gitignore, не коммитится). Реестр env-переменных, которые
# config.yaml читает через ${VAR} или код через os.environ. Для dev (small) хватает дефолтов;
# секреты раскомментировать и заполнить только при использовании соответствующей функции.

# --- Профиль/размещение (не секреты, но per-env) ---
PROFILE=small            # small | large
ROLE=all                 # all (один процесс, dev) | frontend | backend
VECTOR_KIND=chroma       # chroma (small) | qdrant (large)
DATABASE_DSN=sqlite:///codelens.db   # large prod: postgresql+psycopg://user:pass@host/db (секрет, содержит пароль)

# --- Размещение моделей/LLM (large) ---
# EMBEDDER_KIND=remote
# LLM_KIND=remote
# LLM_URL=http://llm:8001
# INFERENCE_URL=http://inference:8000   # либо раздельно EMBEDDER_URL / RERANKER_URL

# --- Секреты: только в .env (dev) / k8s Secret (prod). В config.yaml - лишь ссылки ${VAR} ---
# Ключи облачных LLM (имена должны совпадать с api_key_env провайдеров в config.yaml):
# GROQ_API_KEY=...
# GEMINI_API_KEY=...
# Подпись JWT (в prod задать обязательно; дев-дефолт в config.yaml небезопасен):
# JWT_SECRET=change-me-32+bytes
# Bootstrap первого админа (auth.enabled=true):
# ADMIN_LOGIN=admin
# ADMIN_PASSWORD=...
# Токен Hugging Face для скачивания приватных/gated моделей:
# HF_TOKEN=...
