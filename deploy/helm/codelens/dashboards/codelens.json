{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": ["codelens"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "CodeLens - обзор",
  "uid": "codelens-overview",
  "panels": [
    {
      "title": "HTTP RPS по сервису/маршруту",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (service, route) (rate(codelens_http_requests_total[5m]))",
          "legendFormat": "{{service}} {{route}}"
        }
      ]
    },
    {
      "title": "HTTP p95 латентность",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, service, route) (rate(codelens_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{service}} {{route}}"
        }
      ]
    },
    {
      "title": "Доля ошибок 5xx",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (service) (rate(codelens_http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum by (service) (rate(codelens_http_requests_total[5m])), 1e-9)",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "title": "Cache hit ratio (поиск)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(codelens_cache_total{result=\"hit\"}[15m])) / clamp_min(sum(rate(codelens_cache_total[15m])), 1e-9)",
          "legendFormat": "hit ratio"
        }
      ]
    },
    {
      "title": "Стадии ретривера - p95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, stage) (rate(codelens_retrieval_stage_duration_seconds_bucket[5m])))",
          "legendFormat": "{{stage}}"
        }
      ]
    },
    {
      "title": "Глубина очереди ingest",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (state) (codelens_ingest_queue_jobs)",
          "legendFormat": "{{state}}"
        }
      ]
    },
    {
      "title": "Ingest-job - p95 длительность",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, status) (rate(codelens_ingest_job_duration_seconds_bucket[30m])))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "title": "Ingest-job - успехи/ошибки (rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (status) (rate(codelens_ingest_job_duration_seconds_count[15m]))",
          "legendFormat": "{{status}}"
        }
      ]
    }
  ]
}
