FROM python:3.12-slim
WORKDIR /app
# Воркер ingest: тот же пайплайн, что backend (qdrant/postgres/redis), без моделей,
# эмбеддер удалённый. Группа worker = backend + scale + rq.
COPY pyproject.toml ./
RUN pip install --no-cache-dir ".[worker]"
COPY . .
RUN pip install --no-cache-dir --no-deps .
ENV ROLE=backend
CMD ["python", "-m", "services.worker_app"]
